<?xml version="1.0" encoding="utf-8"?>
<Mapping Space="C-S" xmlns="http://schemas.microsoft.com/ado/2009/11/mapping/cs">
  <EntityContainerMapping StorageEntityContainer="coderbunnyModelStoreContainer" CdmEntityContainer="coderbunnyEntities">
    <EntitySetMapping Name="BoardConfig">
      <EntityTypeMapping TypeName="coderbunnyModel.BoardConfig">
        <MappingFragment StoreEntitySet="BoardConfig">
          <ScalarProperty Name="Id" ColumnName="Id" />
          <ScalarProperty Name="BoardId" ColumnName="BoardId" />
          <ScalarProperty Name="AssetType" ColumnName="AssetType" />
          <ScalarProperty Name="X" ColumnName="X" />
          <ScalarProperty Name="Y" ColumnName="Y" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="CardMaster">
      <EntityTypeMapping TypeName="coderbunnyModel.CardMaster">
        <MappingFragment StoreEntitySet="CardMaster">
          <ScalarProperty Name="CardId" ColumnName="CardId" />
          <ScalarProperty Name="CardName" ColumnName="CardName" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="Game">
      <EntityTypeMapping TypeName="coderbunnyModel.Game">
        <MappingFragment StoreEntitySet="Game">
          <ScalarProperty Name="GameId" ColumnName="GameId" />
          <ScalarProperty Name="DifficultyLevel" ColumnName="DifficultyLevel" />
          <ScalarProperty Name="NumberOfPlayers" ColumnName="NumberOfPlayers" />
          <ScalarProperty Name="GameStatus" ColumnName="GameStatus" />
          <ScalarProperty Name="RoomId" ColumnName="RoomId" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="GameMove">
      <EntityTypeMapping TypeName="coderbunnyModel.GameMove">
        <MappingFragment StoreEntitySet="GameMove">
          <ScalarProperty Name="MoveId" ColumnName="MoveId" />
