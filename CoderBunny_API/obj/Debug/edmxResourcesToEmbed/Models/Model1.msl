          <ScalarProperty Name="DiceValue" ColumnName="DiceValue" />
          <ScalarProperty Name="SequenceId" ColumnName="SequenceId" />
          <ScalarProperty Name="MoveTime" ColumnName="MoveTime" />
          <ScalarProperty Name="FromX" ColumnName="FromX" />
          <ScalarProperty Name="FromY" ColumnName="FromY" />
          <ScalarProperty Name="ToX" ColumnName="ToX" />
          <ScalarProperty Name="ToY" ColumnName="ToY" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="GamePlayers">
      <EntityTypeMapping TypeName="coderbunnyModel.GamePlayers">
        <MappingFragment StoreEntitySet="GamePlayers">
          <ScalarProperty Name="GamePlayerId" ColumnName="GamePlayerId" />
          <ScalarProperty Name="GameId" ColumnName="GameId" />
          <ScalarProperty Name="PlayerId" ColumnName="PlayerId" />
          <ScalarProperty Name="PlayerOrder" ColumnName="PlayerOrder" />
          <ScalarProperty Name="CurrentPosition" ColumnName="CurrentPosition" />
          <ScalarProperty Name="IsActive" ColumnName="IsActive" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="GameTurn">
      <EntityTypeMapping TypeName="coderbunnyModel.GameTurn">
        <MappingFragment StoreEntitySet="GameTurn">
          <ScalarProperty Name="GameTurnId" ColumnName="GameTurnId" />
          <ScalarProperty Name="GameId" ColumnName="GameId" />
          <ScalarProperty Name="CurrentPlayerId" ColumnName="CurrentPlayerId" />
          <ScalarProperty Name="TurnNumber" ColumnName="TurnNumber" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="Player">
      <EntityTypeMapping TypeName="coderbunnyModel.Player">
        <MappingFragment StoreEntitySet="Player">
          <ScalarProperty Name="PlayerId" ColumnName="PlayerId" />
          <ScalarProperty Name="PlayerName" ColumnName="PlayerName" />
          <ScalarProperty Name="PlayerImage" ColumnName="PlayerImage" />
          <ScalarProperty Name="GameId" ColumnName="GameId" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="PlayerCard">
      <EntityTypeMapping TypeName="coderbunnyModel.PlayerCard">
        <MappingFragment StoreEntitySet="PlayerCard">
          <ScalarProperty Name="PlayerCardId" ColumnName="PlayerCardId" />
