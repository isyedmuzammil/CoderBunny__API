    </EntitySetMapping>
    <EntitySetMapping Name="PlayerCardUsage">
      <EntityTypeMapping TypeName="coderbunnyModel.PlayerCardUsage">
        <MappingFragment StoreEntitySet="PlayerCardUsage">
          <ScalarProperty Name="UsageId" ColumnName="UsageId" />
          <ScalarProperty Name="MoveId" ColumnName="MoveId" />
          <ScalarProperty Name="PlayerId" ColumnName="PlayerId" />
          <ScalarProperty Name="GameId" ColumnName="GameId" />
          <ScalarProperty Name="CardId" ColumnName="CardId" />
          <ScalarProperty Name="QuantityUsed" ColumnName="QuantityUsed" />
          <ScalarProperty Name="UsedAt" ColumnName="UsedAt" />
